[user]
    email = aortegapickmans@gmail.com
    name = Alvaro Ortega Pickmans

[includeIf "gitdir:~/work/"]
    path = ~/work/.gitconfig

[core]
    autocrlf = false
    compression = 9
    whitespace = error
    preloadindex = true

[alias]
    st = "status --short"
    ac = "commit -a -m"
    sw = "switch"

[init]
    defaultBranch = main

[status]
    showStash = true
    showUntrackedFiles = all

[diff]
    context = 3
    renames = copies
    interHunkContext = 10

[pager]
    diff = diff-so-fancy | less --tabs=4 -RFX

[diff-so-fancy]
    markEmtpyLines = false

[color "diff"]
    meta = black bold
    frag = magenta
    context = white
    whitespace = yellow reverse
    old = red

[interactive]
    diffFilter = diff-so-fancy --patch
    singlekey = true
